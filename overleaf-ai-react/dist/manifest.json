{
  "manifest_version": 3,
  "name": "My Overleaf AI",
  "version": "1.0",
  "description": "测试 Overleaf 插件开发",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.overleaf.com/*",
    "https://latex.sysu.edu.cn/*",
    "http://192.168.124.22:3000/*"
  ],
  "options_page": "src/extension/options/index.html",
  "action": {
    "default_popup": "src/extension/popup/index.html",
    "default_title": "Overleaf AI Assistant"
  },
  "content_scripts": [
    {
      "js": [
        "assets/main.tsx-loader-5kPvXTJW.js"
      ],
      "matches": [
        "https://www.overleaf.com/*",
        "https://latex.sysu.edu.cn/*",
        "http://192.168.124.22:3000/*"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/main-Ddsimwso.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "http://192.168.124.22:3000/*",
        "https://latex.sysu.edu.cn/*",
        "https://www.overleaf.com/*"
      ],
      "resources": [
        "src/workbench/styles/sidebar.css",
        "injected/overleafBridge.js",
        "assets/client-pkrm3IsY.js",
        "assets/StorageService-lb5uyr0I.js",
        "assets/main.tsx-BbL2ncY0.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
