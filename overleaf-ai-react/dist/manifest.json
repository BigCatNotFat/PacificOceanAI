{
  "manifest_version": 3,
  "name": "My Overleaf AI",
  "version": "1.0",
  "description": "测试 Overleaf 插件开发",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.overleaf.com/*"
  ],
  "options_page": "src/extension/options/index.html",
  "action": {
    "default_popup": "src/extension/popup/index.html",
    "default_title": "Overleaf AI Assistant"
  },
  "content_scripts": [
    {
      "js": [
        "assets/main.tsx-loader-DndVRIC_.js"
      ],
      "matches": [
        "https://www.overleaf.com/*"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/main-DbrKFK2W.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.overleaf.com/*"
      ],
      "resources": [
        "src/workbench/styles/sidebar.css",
        "injected/overleafBridge.js",
        "assets/client-BaofO1uk.js",
        "assets/StorageService-DSiMnXGx.js",
        "assets/main.tsx-DBGoxUux.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
