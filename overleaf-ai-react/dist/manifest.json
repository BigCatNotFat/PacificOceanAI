{
  "manifest_version": 3,
  "name": "My Overleaf AI",
  "version": "1.0",
  "description": "测试 Overleaf 插件开发",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "options_page": "src/extension/options/index.html",
  "action": {
    "default_popup": "src/extension/popup/index.html",
    "default_title": "Overleaf AI Assistant"
  },
  "content_scripts": [
    {
      "js": [
        "assets/main.tsx-loader-CDJ9ZTaV.js"
      ],
      "matches": [
        "https://www.overleaf.com/*"
      ],
      "css": [
        "assets/main-CG2LvAlY.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.overleaf.com/*"
      ],
      "resources": [
        "src/workbench/styles/sidebar.css",
        "assets/client-BaofO1uk.js",
        "assets/main.tsx-D9GTjceR.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
